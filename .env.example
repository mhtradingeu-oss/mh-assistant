# ─────────────────────────────────────────────────────────────────────────────
# mh-assistant — required environment variables
# Copy this file to .env (not committed) and fill in real values.
# .env is gitignored. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# TCP port for the orchestrator HTTP service.
PORT=3000

# Node environment. Set to 'production' in prod.
NODE_ENV=development

# ── Control centre write key ──────────────────────────────────────────────────
# Required. Protects all state-mutating routes from unauthorised access.
# Must be a randomly generated secret string (e.g. openssl rand -hex 32).
# Provide in request header: x-mh-control-key: <value>
#   OR as:                   Authorization: Bearer <value>
MH_CONTROL_CENTER_WRITE_KEY=replace-with-random-secret

# ── Integration encryption master key ────────────────────────────────────────
# Optional but strongly recommended for production.
# When set, the integration credential encryption key is read from this env var
# (base64-encoded 32-byte key) instead of data/system/integration-secret.key.json.
#
# Generate a key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# ⚠  If you previously used a file-based key, all stored encrypted credentials
#    were encrypted with that key. Changing the key will require re-entering
#    all integration credentials. Rotate the key only during a planned migration.
MH_INTEGRATION_SECRET_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for AI content generation features.
OPENAI_API_KEY=sk-replace-with-real-key

# ── WooCommerce ───────────────────────────────────────────────────────────────
# Required for product sync, order intelligence, and commerce features.
WC_BASE_URL=https://your-store.example.com/wp-json/wc/v3
WC_KEY=ck_replace-with-consumer-key
WC_SECRET=cs_replace-with-consumer-secret

# ── WordPress / WP REST API ───────────────────────────────────────────────────
# Required for WordPress publishing integration.
WP_BASE_URL=https://your-wordpress.example.com
WP_USER=your-wp-username
WP_APP_PASSWORD=replace-with-app-password

# ── Email bridge ─────────────────────────────────────────────────────────────
# Required for email send integration.
MH_EMAIL_BRIDGE_URL=https://your-email-bridge.example.com
MH_EMAIL_BRIDGE_TOKEN=replace-with-bridge-token

# ── Data path flags (optional, for dual-path migration) ──────────────────────
# These control legacy vs canonical data path routing. Leave blank for defaults.
EXECUTION_CANONICAL_READ=
EXECUTION_CANONICAL_WRITE=
LEGACY_FALLBACK_READ=
LEGACY_MIRROR_WRITE=
CAMPAIGN_EXECUTION_READ_CANONICAL_FIRST=
CAMPAIGN_FINALIZATION_READ_CANONICAL_FIRST=
CHANNEL_PACKAGES_READ_CANONICAL_FIRST=
EMAIL_READ_CANONICAL_FIRST=
EXECUTION_RESULTS_READ_CANONICAL_FIRST=
GENERATED_READ_CANONICAL_FIRST=
PUBLISHING_READ_CANONICAL_FIRST=

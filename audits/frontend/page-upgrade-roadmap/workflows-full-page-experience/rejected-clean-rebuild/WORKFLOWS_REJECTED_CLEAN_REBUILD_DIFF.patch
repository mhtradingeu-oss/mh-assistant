+
+  .wfexec-overview-grid-rich {
+    grid-template-columns: repeat(3, minmax(0, 1fr));
+  }
+
+  .wfexec-loop-strip {
+    grid-template-columns: repeat(3, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 820px) {
+  .wfexec-field-grid,
+  .wfexec-overview-grid,
+  .wfexec-overview-grid-rich,
+  .wfexec-loop-strip,
+  .wfexec-loop-health,

+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+  color: var(--color-text-2);
+}
+
+.wfexec-catalog-badge.is-cyan {
+  border-color: rgba(34, 211, 238, 0.32);
+  background: rgba(8, 145, 178, 0.2);
+}
+
+.wfexec-catalog-badge.is-teal {
+  border-color: rgba(45, 212, 191, 0.32);
+  background: rgba(13, 148, 136, 0.22);
+}
+
+.wfexec-catalog-badge.is-blue {
+  border-color: rgba(96, 165, 250, 0.32);
+  background: rgba(37, 99, 235, 0.2);
+}
+
+.wfexec-catalog-badge.is-amber {
+  border-color: rgba(251, 191, 36, 0.36);
+  background: rgba(180, 83, 9, 0.24);
+}
+
+.wfexec-catalog-badge.is-slate {
+  border-color: rgba(148, 163, 184, 0.32);
+  background: rgba(71, 85, 105, 0.24);
+}
+
+.wfexec-catalog-badge.is-violet {
+  border-color: rgba(196, 181, 253, 0.34);
+  background: rgba(109, 40, 217, 0.22);
+}
+
+.wfexec-catalog-badge.is-rose {
+  border-color: rgba(251, 113, 133, 0.34);
+  background: rgba(190, 24, 93, 0.24);

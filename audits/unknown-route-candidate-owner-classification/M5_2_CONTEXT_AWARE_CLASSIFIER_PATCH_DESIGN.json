  "problem": {
    "current_behavior": "Classifier uses identifier-first classification and sends unresolved values directly to unknown_candidate.",
    "risk": "Generic vocabulary and internal identifiers can be confused with real page routes.",
    "goal": "Reduce false positives without hiding genuine unknown routes."
  },
  "classification_pipeline": [
    "canonical_contract_page",
    "runtime_page_alias",
    "role_id",
    "role_alias",
    "known_non_page",
    "provider_integration_channel",
    "status_lifecycle_identifier",
    "internal_ai_decision_route",
    "ui_action_event",
    "subsystem_handoff_source",
    "unknown_candidate"
  ],
  "safety_invariants": [
    "Unknown candidates remain the final fallback.",
    "No token is classified without evidence context.",
    "No broad ignore list is allowed.",
    "No unknown route receives an artificial owner.",
    "Real future pages must remain detectable."
  ],
  "context_model": {
    "required_evidence": [
      "identifier value",
      "source file",
      "source field",
      "syntax context",
      "known contract/runtime relationships"
    ]
  },
  "candidate_rules": [
    {
      "token": "action",
      "classification": "ui_action_event",
      "owner": null
    },
    {
      "token": "analysis",
      "classification": "internal_ai_decision_route",
      "owner": null
    },
    {
      "token": "automation-engine",
      "classification": "subsystem_handoff_source",
      "owner": null
    },
    {
      "token": "command",

      "owner": null
    },
    {
      "token": "idle",
      "classification": "status_lifecycle_identifier",
      "owner": null
    },
    {
      "token": "set-page",
      "classification": "ui_action_event",
      "owner": null
    }
  ],
  "implementation_scope_for_m5_2": {
    "target_file": "scripts/audit/ai-team-contract-conformance-check.mjs",
    "allowed": [
      "Add context-aware classifier helpers.",
      "Add evidence-based buckets.",
      "Preserve unknown_candidate fallback.",
      "Improve reporting."
    ],
    "forbidden": [
      "Do not change application runtime.",
      "Do not change AI Command.",

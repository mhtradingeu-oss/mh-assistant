{
  "version": "1.0.0",
  "platforms": {
    "instagram": {
      "format": "9:16",
      "duration": "15-30s",
      "priority": ["visual polish", "brand consistency", "clear CTA"],
      "notes": "Keep text short and safe within vertical safe zones."
    },
    "tiktok": {
      "format": "9:16",
      "duration": "10-25s",
      "priority": ["fast hook", "native energy", "simple story"],
      "notes": "Avoid looking too corporate; keep motion natural."
    },
    "youtube": {
      "format": "9:16 or 16:9",
      "duration": "15-60s",
      "priority": ["title alignment", "story clarity", "retention"],
      "notes": "Make the first 3 seconds match the title promise."
    },
    "amazon": {
      "format": "1:1 or 16:9",
      "duration": "15-45s",
      "priority": ["product clarity", "usage", "trust"],
      "notes": "Avoid unsupported claims and distracting backgrounds."
    },
    "website": {
      "format": "16:9 or 1:1",
      "duration": "10-30s",
      "priority": ["premium hero", "brand trust", "conversion"],
      "notes": "Use slower premium pacing than TikTok."
    }
  }
}
